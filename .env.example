# ============================================================================
# Sam_Invest - secrets et configuration sensible
# Copie ce fichier en ".env" (sans extension) et remplis les valeurs.
# Le fichier .env n'est JAMAIS versionne (voir .gitignore).
# ============================================================================

# --- API Claude (couche jugement : resume/classe les news + synthese) -------
# Obligatoire pour le bouton "Briefing". Sans cle, le briefing affiche
# quand meme tous les chiffres mais sans la synthese en langage naturel.
ANTHROPIC_API_KEY=

# Modeles Claude (IDs verifies valides au moment du build).
# Haiku = classer/resumer les news (rapide, pas cher).
# Sonnet = synthese finale en langage naturel.
CLAUDE_MODEL_HAIKU=claude-haiku-4-5
CLAUDE_MODEL_SONNET=claude-sonnet-4-6

# --- Sources de donnees financieres (fondamentaux + news) -------------------
# yfinance est essaye EN PREMIER (gratuit, sans cle). Ces cles servent de
# repli / enrichissement. Laisse vide si tu n'as pas de compte : l'app
# se rabattra sur ce qui est disponible sans planter.
#
# Finnhub (tier gratuit) : https://finnhub.io/  -> repli n°1
FINNHUB_API_KEY=

# Financial Modeling Prep (tier gratuit) : https://site.financialmodelingprep.com/  -> repli n°2
FMP_API_KEY=

# --- SMTP (email) -----------------------------------------------------------
# Non utilise pour l'instant (fonctionnalite email reportee).
# Laisse vide. Sera reactive plus tard si besoin.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_TO=
